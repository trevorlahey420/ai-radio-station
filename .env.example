# ============================================================
# Radio Free Gonzo — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# ── LLM PROVIDERS (at least one required) ────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# ── LLM ROUTING (optional overrides) ─────────────────────────
# LLM_PLAYLIST_PROVIDER=openai
# LLM_PLAYLIST_MODEL=gpt-4o
# LLM_DJ_PROVIDER=anthropic
# LLM_DJ_MODEL=claude-3-5-sonnet-20241022
# LLM_NEWS_PROVIDER=openai
# LLM_NEWS_MODEL=gpt-4o-mini

# ── TTS (DJ Voice) ───────────────────────────────────────────
# Provider set in config/preferences.yaml (dj_voice_provider)
ELEVENLABS_API_KEY=your_elevenlabs_key
ELEVENLABS_VOICE_ID=your_voice_id
# For OpenAI TTS: set dj_voice_provider: openai in preferences.yaml

# ── ICECAST STREAMING SERVER ──────────────────────────────────
ICECAST_HOST=localhost
ICECAST_PORT=8000
ICECAST_PASSWORD=hackme
ICECAST_MOUNT=/stream
ICECAST_ADMIN_PASSWORD=admin

# ── NEWS & WEATHER ────────────────────────────────────────────
NEWSAPI_KEY=your_newsapi_key          # https://newsapi.org
OPENWEATHER_KEY=your_openweather_key  # https://openweathermap.org/api

# ── DISCORD BOT (optional) ────────────────────────────────────
DISCORD_BOT_TOKEN=your_discord_bot_token
DISCORD_REQUEST_CHANNEL=song-requests
DISCORD_ADMIN_ROLE=DJ Admin

# ── WEB API ───────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8080

# ── LOCAL LLM (optional - Ollama) ────────────────────────────
# LOCAL_LLM_BASE_URL=http://localhost:11434/v1
